{
  "name": "alynt-drime-backups-uploader",
  "version": "0.5.2",
  "private": true,
  "description": "Upload completed backup packages to Drime.",
  "type": "module",
  "scripts": {
    "build": "npm run build:runner && npm run build:assets",
    "build:assets": "node scripts/build.mjs",
    "build:runner": "node scripts/build-runner.mjs",
    "verify:runner": "node scripts/verify-runner-build.mjs",
    "verify:release-zip": "node scripts/verify-release-zip.mjs",
    "lint:runner": "node scripts/lint-runner.mjs",
    "dev": "node scripts/build-runner.mjs && node scripts/build.mjs --watch",
    "deploy": "bash deploy.sh",
    "deploy:watch": "nodemon --watch . --ext php,js,css,html --ignore node_modules/ --ignore .git/ --ignore scripts/ --delay 2 --exec \"bash deploy.sh\"",
    "dev:all": "concurrently --names \"build,deploy\" --prefix-colors \"cyan,magenta\" \"npm run dev\" \"npm run deploy:watch\"",
    "lint": "php ./vendor/bin/phpcs --standard=.phpcs.xml",
    "lint:fix": "php ./vendor/bin/phpcbf --standard=.phpcs.xml",
    "test": "php ./vendor/bin/phpunit",
    "test:coverage": "php ./vendor/bin/phpunit --coverage-html=coverage/",
    "pot": "wp i18n make-pot . languages/alynt-drime-backups-uploader.pot"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.0"
  }
}
